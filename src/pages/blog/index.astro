---
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = [
  {
    slug: 'mattress-buying-guide',
    title: 'Complete Mattress Buying Guide 2026',
    description: 'Learn how to choose the perfect mattress based on sleep position, firmness, and budget.',
    date: 'March 3, 2026',
    readTime: '10 min read',
  },
];
---

<BaseLayout
  title="Mattress Buying Guides - MattressRank.info Blog"
  description="Expert mattress guides and buying tips to help you choose the perfect bed for better sleep."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4">Mattress Buying Guides</h1>
    <p class="text-xl text-gray-600 mb-12">
      Expert advice on choosing the perfect mattress for your sleep style and budget.
    </p>

    <div class="space-y-8">
      {blogPosts.map(post => (
        <article class="border-b pb-8">
          <a href={`/blog/${post.slug}/`} class="group">
            <h2 class="text-2xl font-semibold mb-2 group-hover:text-blue-600 transition">
              {post.title}
            </h2>
          </a>
          <div class="text-sm text-gray-500 mb-3">
            {post.date} · {post.readTime}
          </div>
          <p class="text-gray-700 mb-4">
            {post.description}
          </p>
          <a href={`/blog/${post.slug}/`} class="text-blue-600 hover:underline">
            Read more →
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
