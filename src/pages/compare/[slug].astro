---
import comparisonSeo from '../../data/comparison-seo.json';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  const paths: any[] = [];
  
  const tools = listings.map(l => l.data);
  
  for (let i = 0; i < tools.length; i++) {
    for (let j = i + 1; j < tools.length; j++) {
      const [a, b] = [tools[i], tools[j]].sort((x, y) => x.slug.localeCompare(y.slug));
      paths.push({
        params: { slug: `${a.slug}-vs-${b.slug}` },
        props: { toolA: a, toolB: b },
      });
    }
  }
  
  return paths;
}

const { toolA, toolB } = Astro.props;

// SEO optimization lookup
const slug = Astro.params.slug;
const seoData = comparisonSeo[slug] || {};
const pageTitle = `${toolA.name} vs ${toolB.name} — Detailed Comparison 2026`;
const pageDesc = `Compare ${toolA.name} and ${toolB.name} side by side. Features, pricing, pros & cons.`;

const ratingA = typeof toolA.rating === 'number' ? toolA.rating : toolA.rating?.overall || 'N/A';
const ratingB = typeof toolB.rating === 'number' ? toolB.rating : toolB.rating?.overall || 'N/A';

// Price helper — supports both the mattress schema (pricing.price/salePrice) and the tools schema (startingPrice/model)
const priceOf = (t: any) => {
  const p = t.pricing || {};
  if (p.price) return p.salePrice ? `${p.salePrice} (was ${p.price})` : p.price;
  return p.startingPrice || p.model || 'varies';
};
const priceA = priceOf(toolA);
const priceB = priceOf(toolB);
const bestA = (toolA.bestFor && toolA.bestFor[0]) || toolA.subcategory || toolA.category;
const bestB = (toolB.bestFor && toolB.bestFor[0]) || toolB.subcategory || toolB.category;
const specLine = (t: any) => [t.specs?.material, t.specs?.firmness].filter(Boolean).join(', ');
const specA = specLine(toolA);
const specB = specLine(toolB);

// Answer-first verdict (data-driven, grounded — no fabricated facts)
const verdict =
  `${toolA.name} (rated ${ratingA}/5${priceA !== 'varies' ? `, ${priceA}` : ''}) and ${toolB.name} (rated ${ratingB}/5${priceB !== 'varies' ? `, ${priceB}` : ''}) are both strong picks, so the right one depends on fit. ` +
  `Choose the ${toolA.name} if you want ${String(bestA).toLowerCase()}${specA ? ` — it's a ${specA} build` : ''}. ` +
  `Choose the ${toolB.name} if you want ${String(bestB).toLowerCase()}${specB ? ` (${specB})` : ''}. ` +
  `${ratingA !== 'N/A' && ratingB !== 'N/A' && ratingA !== ratingB ? `On our overall score the ${(ratingA > ratingB ? toolA : toolB).name} edges ahead (${Math.max(ratingA, ratingB)} vs ${Math.min(ratingA, ratingB)}). ` : ''}` +
  `Match the firmness and best-for below to your sleep position and budget before deciding.`;

const faqs = [
  {
    question: `Is ${toolA.name} better than ${toolB.name}?`,
    answer: `${toolA.name} is rated ${ratingA}/5 while ${toolB.name} is rated ${ratingB}/5. ${toolA.name} best suits ${String(bestA).toLowerCase()}, whereas ${toolB.name} best suits ${String(bestB).toLowerCase()} — so the better choice depends on your sleep position, firmness preference and budget.`,
  },
  {
    question: `What is the price difference between ${toolA.name} and ${toolB.name}?`,
    answer: `${toolA.name} is ${priceA}. ${toolB.name} is ${priceB}. Check for current sales, as mattress prices change frequently.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---


<BaseLayout
  title={seoData.seoTitle || pageTitle}
  description={seoData.seoDescription || pageDesc}
  canonical={`https://mattressrank.info/compare/${toolA.slug}-vs-${toolB.slug}`}
>
  <article class="max-w-4xl mx-auto px-4">
    <div class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-blue-600">Home</a> / Compare / {toolA.name} vs {toolB.name}
    </div>

    <h1 class="text-3xl font-bold mb-4">{pageTitle}</h1>

    <!-- Answer-first verdict (GEO evidence container) -->
    <section class="mb-8 bg-blue-50 border border-blue-100 rounded-lg p-5">
      <p class="text-gray-800 leading-relaxed">{verdict}</p>
    </section>

    <div class="grid md:grid-cols-2 gap-6 mb-10">
      {[toolA, toolB].map((tool) => (
        <div class="border rounded-lg p-5">
          <h2 class="text-xl font-bold mb-2">{tool.name}</h2>
          <p class="text-sm text-gray-500 mb-3">{tool.tagline || tool.description?.slice(0, 100)}</p>
          {tool.rating && <div class="text-yellow-600 font-semibold mb-3">★ {typeof tool.rating === 'number' ? tool.rating.toFixed(1) : tool.rating.overall?.toFixed(1) || 'N/A'}/5</div>}
          
          {tool.pricing && (
            <div class="mb-3">
              <span class="text-xs font-medium uppercase text-gray-400">Pricing</span>
              <p>{priceOf(tool)}</p>
            </div>
          )}

          {tool.features && (
            <div class="mb-3">
              <span class="text-xs font-medium uppercase text-gray-400">Features</span>
              <ul class="mt-1 space-y-1">
                {tool.features.slice(0, 5).map((f: any) => (
                  <li class="text-sm">✓ {typeof f === 'string' ? f : f.name || f}</li>
                ))}
              </ul>
            </div>
          )}

          <div class="mt-4">
            <a href={`/listing/${tool.slug}`} class="text-sm px-4 py-2 bg-gray-100 rounded hover:bg-gray-200 inline-block">View Details</a>
          </div>
        </div>
      ))}
    </div>

    <FAQSection faqs={faqs} title={`${toolA.name} vs ${toolB.name} — FAQ`} />
  </article>
</BaseLayout>
